        <addForeignKeyConstraint baseTableName="attendance_qr_challenges" baseColumnNames="company_id"
                                 constraintName="fk_attendance_qr_challenges_company"
                                 referencedTableName="companies" referencedColumnNames="id"/>
        <addForeignKeyConstraint baseTableName="attendance_qr_challenges" baseColumnNames="site_id"
                                 constraintName="fk_attendance_qr_challenges_site"
                                 referencedTableName="company_sites" referencedColumnNames="id"/>
        <addForeignKeyConstraint baseTableName="attendance_qr_challenges" baseColumnNames="qr_terminal_id"
