            <column name="company_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="site_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="qr_terminal_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="nonce" type="VARCHAR(128)">
                <constraints nullable="false"/>
            </column>
            <column name="token_hash" type="VARCHAR(128)">
                <constraints nullable="false"/>
            </column>
            <column name="issued_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="expires_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="used_at" type="DATETIME"/>
            <column name="used_by_user_id" type="UUID"/>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
