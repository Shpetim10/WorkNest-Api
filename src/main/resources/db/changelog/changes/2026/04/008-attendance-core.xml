<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">

    <changeSet id="008-1" author="codex">
        <createTable tableName="attendance_policies">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="company_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="site_id" type="UUID"/>
            <column name="require_qr" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="require_location" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="check_in_enabled" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="check_out_enabled" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="use_network_as_warning" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="reject_outside_geofence" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="reject_poor_accuracy" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="allow_manual_correction" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="allow_manager_manual_entry" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="missing_checkout_auto_close_enabled" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="auto_checkout_after_minutes" type="INT"/>
            <column name="late_grace_minutes" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="early_clock_in_window_minutes" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="attendance_policies" baseColumnNames="company_id"
                                 constraintName="fk_attendance_policies_company"
                                 referencedTableName="companies" referencedColumnNames="id"/>
        <addForeignKeyConstraint baseTableName="attendance_policies" baseColumnNames="site_id"
                                 constraintName="fk_attendance_policies_site"
                                 referencedTableName="company_sites" referencedColumnNames="id"/>

        <addUniqueConstraint tableName="attendance_policies" constraintName="uk_attendance_policies_company_site"
                             columnNames="company_id, site_id"/>
        <createIndex tableName="attendance_policies" indexName="idx_attendance_policies_company">
            <column name="company_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="008-2" author="codex">
        <createTable tableName="attendance_qr_terminals">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="company_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="site_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(120)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="rotation_seconds" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="secret_key_version" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="auto_created" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="last_heartbeat_at" type="DATETIME"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="attendance_qr_terminals" baseColumnNames="company_id"
                                 constraintName="fk_attendance_qr_terminals_company"
                                 referencedTableName="companies" referencedColumnNames="id"/>
        <addForeignKeyConstraint baseTableName="attendance_qr_terminals" baseColumnNames="site_id"
                                 constraintName="fk_attendance_qr_terminals_site"
                                 referencedTableName="company_sites" referencedColumnNames="id"/>

        <addUniqueConstraint tableName="attendance_qr_terminals"
                             constraintName="uk_attendance_qr_terminals_company_site_name"
                             columnNames="company_id, site_id, name"/>
        <createIndex tableName="attendance_qr_terminals" indexName="idx_attendance_qr_terminals_site_status">
            <column name="site_id"/>
            <column name="status"/>
        </createIndex>
    </changeSet>

    <changeSet id="008-3" author="codex">
