        </addColumn>
    </changeSet>
    <changeSet id="1775002176060-29" author="shaba">
        <addNotNullConstraint columnName="last_name" tableName="users"/>
    </changeSet>
    <changeSet id="1775002176060-33" author="shaba">
        <addNotNullConstraint columnName="mfa_enabled" tableName="users"/>
    </changeSet>
    <changeSet id="1775002176060-35" author="shaba">
        <addColumn tableName="role_assignments">
            <column name="mobile_feature_scope" type="VARCHAR(50)"/>
            <column name="platform_access" type="VARCHAR(10)"/>
        </addColumn>
    </changeSet>
    <changeSet id="1775002176060-42" author="shaba">
        <addColumn tableName="refresh_tokens">
            <column name="platform_access" type="VARCHAR(10)"/>
        </addColumn>
    </changeSet>
