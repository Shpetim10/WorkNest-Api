    </changeSet>
    <changeSet id="1775002176060-14" author="shaba">
        <addNotNullConstraint columnName="country_code" tableName="companies"/>
    </changeSet>
    <changeSet id="1775002176060-16" author="shaba">
        <addNotNullConstraint columnName="currency" tableName="companies"/>
    </changeSet>
    <changeSet id="1775002176060-18" author="shaba">
        <addNotNullConstraint columnName="date_format" tableName="companies"/>
    </changeSet>
