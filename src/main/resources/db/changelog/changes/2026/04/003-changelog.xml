            <column name="profile_image_s3_key" type="VARCHAR(500)"/>
            <column name="timezone_override" type="VARCHAR(100)"/>
            <column name="username" type="VARCHAR(100)"/>
        </addColumn>
    </changeSet>
    <changeSet id="1775002176060-21" author="shaba">
        <addNotNullConstraint columnName="first_name" tableName="users"/>
