    </changeSet>
    <changeSet id="1775002176060-69" author="shaba">
        <createIndex indexName="idx_users_company_status" tableName="users">
            <column name="company_id"/>
            <column name="status"/>
        </createIndex>
    </changeSet>
    <changeSet id="1775002176060-70" author="shaba">
        <createIndex indexName="idx_users_company_username" tableName="users">
            <column name="company_id"/>
            <column name="username"/>
        </createIndex>
    </changeSet>
    <changeSet id="1775002176060-1" author="shaba">
        <modifyDataType columnName="description" newDataType="VARCHAR(255)" tableName="permissions"/>
    </changeSet>
    <changeSet id="1775002176060-2" author="shaba">
        <modifyDataType columnName="description" newDataType="VARCHAR(255)" tableName="platform_events"/>
    </changeSet>
