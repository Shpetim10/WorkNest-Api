    </changeSet>
    <changeSet id="1775002176060-60" author="shaba">
        <addNotNullConstraint columnName="subscription_status" tableName="companies"/>
    </changeSet>
    <changeSet id="1775002176060-68" author="shaba">
        <addUniqueConstraint columnNames="company_id, username" constraintName="uk_users_company_username"
