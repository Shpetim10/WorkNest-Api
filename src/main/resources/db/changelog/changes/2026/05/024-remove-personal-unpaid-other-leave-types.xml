<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="024-1" author="worknest">
        <comment>Remove leave balances for deprecated types: PERSONAL, UNPAID, OTHER</comment>
        <delete tableName="leave_balances">
            <where>leave_type IN ('PERSONAL', 'UNPAID', 'OTHER')</where>
        </delete>
    </changeSet>

    <changeSet id="024-2" author="worknest">
        <comment>Remove leave requests for deprecated types: PERSONAL, UNPAID, OTHER</comment>
        <delete tableName="leave_requests">
            <where>leave_type IN ('PERSONAL', 'UNPAID', 'OTHER')</where>
        </delete>
    </changeSet>

</databaseChangeLog>
