<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">

    <!-- Rename estimated_weekly_hours to daily_working_hours; field now represents hours per day directly -->
    <changeSet id="015-1" author="codex">
        <renameColumn tableName="employees"
                      oldColumnName="estimated_weekly_hours"
                      newColumnName="daily_working_hours"
                      columnDataType="NUMERIC(4,1)"/>
    </changeSet>

</databaseChangeLog>
